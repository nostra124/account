#!/bin/bash
# rpk package phase: stage a bundle for $1 at
# $(rpk bundle $(rpk type))/<package>-<version>/ per docs/PACKAGING.md.
#
# The previous version called `./configure && make install`, which made
# the Makefile run its own `stow -t $PREFIX` and bypassed rpk's outer
# stow into $(rpk target). rpk packages must hand back a plain tree;
# the stow step is rpk's job, not the Makefile's.

set -eu

die() { echo "$@" >&2; exit 100; }

PACKAGE=$(rpk identity)
VERSION=${1:-}
[ -n "$VERSION" ] || VERSION=$(rpk versions | tail -1)

COMMIT=$(rpk commit "$VERSION")
[ -n "$COMMIT" ] || die "version $VERSION has no commit hash"

TARGET=$(rpk bundle "$(rpk type)")/$PACKAGE-$VERSION

BRANCH=$(git branch --show-current)
trap 'git checkout "$BRANCH" --force >/dev/null 2>&1 || true' EXIT

git config advice.detachedHead false
git checkout "$COMMIT" || die "failed to checkout $COMMIT"

mkdir -p \
	"$TARGET/bin" \
	"$TARGET/libexec/$PACKAGE" \
	"$TARGET/etc/bash_completion.d" \
	"$TARGET/share/man/man1" \
	"$TARGET/share/doc/$PACKAGE" \
	"$TARGET/share/$PACKAGE"

cp -a bin/. "$TARGET/bin/"

if [ -d "libexec/$PACKAGE" ]; then
	cp -a "libexec/$PACKAGE/." "$TARGET/libexec/$PACKAGE/"
fi
if [ -d etc/bash_completion.d ]; then
	cp -a etc/bash_completion.d/. "$TARGET/etc/bash_completion.d/"
fi
if [ -d share/man/man1 ]; then
	cp -a share/man/man1/. "$TARGET/share/man/man1/"
fi
if [ -d "share/doc/$PACKAGE" ]; then
	cp -a "share/doc/$PACKAGE/." "$TARGET/share/doc/$PACKAGE/"
fi
# .rpk/version → share/<pkg>/version: the runtime version file the
# binary's two-path fallback resolves when invoked as the installed
# entry (FEAT-194).
if [ -f .rpk/version ]; then
	install -m 644 .rpk/version "$TARGET/share/$PACKAGE/version"
fi

git checkout "$BRANCH" --force
